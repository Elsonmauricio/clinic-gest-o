{
  "version": 2,
  "builds": [
    {
      "src": "server/_core/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/_core/index.ts" },
    { "src": "/trpc/(.*)", "dest": "server/_core/index.ts" },
    { "src": "/(.*)", "dest": "client/dist/$1", "check": true },
    { "src": "/(.*)", "dest": "client/dist/index.html" }
  ]
}